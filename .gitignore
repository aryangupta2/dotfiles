# Deny by default. Only paths already tracked in this repo are allowlisted.
# Untracked files stay on disk; git just ignores them.
*
!*/

# Root
!.gitignore
!Brewfile
!README.md
!bootstrap.sh

# agents
!agents/**

# config
!config/.config/alacritty/alacritty.toml
!config/.config/gh/config.yml

# cursor
!cursor/.cursor/rules/**
!cursor/Library/Application Support/Cursor/User/settings.json
!cursor/Library/Application Support/Cursor/User/keybindings.json

# git / zsh
!git/**
!zsh/**

#raycast
raycast/